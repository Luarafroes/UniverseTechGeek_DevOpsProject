@model Universetechgeek.Models.MediaDetailsViewModel<Universetechgeek.Models.Movie>

@{
    ViewData["MediaTitle"] = Model.Media?.Title ?? "Movie Details";
    ViewData["MediaType"] = "Movie";
    ViewData["MediaId"] = Model.Media?.Id.ToString();
    ViewData["ImageUrl"] = Model.Media?.ImageUrl;
}

<main class="container mx-auto py-12 px-4">

    @if (Model.Media == null)
    {
        <p class="text-gray-500">Filme não encontrado.</p>
    }
    else
    {
        <div class="book-container">
            <div class="book-cover shadow-2xl overflow-hidden rounded-xl">
                <img src="@Model.Media.ImageUrl" alt="@Model.Media.Title" class="w-full h-full object-cover" />
            </div>
            <div class="space-y-6">
                <div class="flex items-start justify-between flex-wrap gap-4">
                    <div>
                        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter">@Model.Media.Title</h1>
                    </div>
                    <div class="rating-badge text-white">@Model.Media.Rating</div>
                </div>
                <p class="text-gray-600 text-lg leading-relaxed">@Model.Media.Description</p>
            </div>
        </div>

        @await Html.PartialAsync("_ReviewSection", Model as dynamic, new ViewDataDictionary(ViewData)
        {
            { "MediaType", "Movie" },
        { "MediaId", Model.Media.Id.ToString() },
        { "Title", Model.Media.Title },
        { "ImageUrl", Model.Media.ImageUrl }
        })
        }

</main>