@model Universetechgeek.Models.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section style="padding:48px 0; background:#0a0a0a; border-bottom:1px solid #1a1a1a;">
    <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8 items-center">
            <div>
                <h1 class="text-5xl font-extrabold mb-4 tracking-tight" style="color:#fff;">Descubra a tua próxima paixão.</h1>
                <p class="text-xl mb-8" style="color:#aaa;">O melhor guia para entretenimento. Críticas, lançamentos e tendências num só lugar.</p>
                <div style="display:flex; gap:12px; flex-wrap:wrap;">
                    <a href="/Games" style="background:#ef4444; color:#fff; padding:12px 24px; border-radius:8px; font-weight:700; font-size:14px;">Ver Jogos</a>
                    <a href="/Movies" style="background:transparent; color:#fff; padding:12px 24px; border-radius:8px; font-weight:700; font-size:14px; border:2px solid #444;">Ver Filmes</a>
                </div>

                <!-- Dots indicator -->
                <div style="display:flex; gap:8px; margin-top:32px;" id="hero-dots">
                    @{
                        var heroItems = new List<(string Title, string ImageUrl, string Url, string Type, double Rating)>();
                        foreach (var g in Model.Games.Take(2))
                            heroItems.Add((g.Title, g.ImageUrl, $"/Games/Details/{g.Id}", "Jogo", g.Rating));
                        foreach (var m in Model.Movies.Take(2))
                            heroItems.Add((m.Title, m.ImageUrl, $"/Movies/Details/{m.Id}", "Filme", m.Rating));
                        foreach (var s in Model.TvShows.Take(2))
                            heroItems.Add((s.Title, s.ImageUrl, $"/TvShows/Details/{s.Id}", "Série", s.Rating));
                        foreach (var a in Model.Animes.Take(2))
                            heroItems.Add((a.Title, a.ImageUrl, $"/Animes/Details/{a.Id}", "Anime", a.Rating));
                        foreach (var b in Model.Books.Take(1))
                            heroItems.Add((b.Title, b.ImageUrl, $"/Books/Details/{b.Id}", "Livro", b.Rating));
                    }
                    @for (int i = 0; i < heroItems.Count; i++)
                    {
                        <button onclick="goToSlide(@i)"
                                style="width:@(i == 0 ? "24px" : "8px"); height:8px; border-radius:@(i == 0 ? "4px" : "50%"); border:none; cursor:pointer; transition:all 0.3s; background:@(i == 0 ? "#ef4444" : "#444");"
                                class="hero-dot">
                        </button>
                    }
                </div>
            </div>

            <!-- Slideshow -->
            <div style="position:relative; border-radius:16px; overflow:hidden; height:320px;">
                @for (int i = 0; i < heroItems.Count; i++)
                {
                    var item = heroItems[i];
                    <a href="@item.Url"
                       style="position:absolute; inset:0; opacity:@(i == 0 ? "1" : "0"); transition:opacity 0.8s ease; display:block;"
                       class="hero-slide">
                        <img src="@item.ImageUrl" alt="@item.Title"
                             style="width:100%; height:100%; object-fit:cover; display:block;"
                             onerror="this.src='/img/no-cover.jpg'" />
                        <div style="position:absolute; bottom:0; left:0; right:0; padding:20px; background:linear-gradient(to top, rgba(0,0,0,0.85), transparent);">
                            <span style="background:#ef4444; color:#fff; font-size:10px; font-weight:700; padding:2px 8px; border-radius:3px; text-transform:uppercase; letter-spacing:0.1em;">@item.Type</span>
                            <p style="color:#fff; font-weight:700; font-size:16px; margin:6px 0 0;">@item.Title</p>
                            @if (item.Rating > 0)
                            {
                                <p style="color:#facc15; font-size:13px; margin:4px 0 0;">★ @item.Rating</p>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

<script>
    let currentSlide = 0;
    const slides = document.querySelectorAll('.hero-slide');
    const dots = document.querySelectorAll('.hero-dot');
    const totalSlides = slides.length;

    function goToSlide(index) {
        slides[currentSlide].style.opacity = '0';
        dots[currentSlide].style.background = '#444';
        dots[currentSlide].style.width = '8px';
        dots[currentSlide].style.borderRadius = '50%';

        currentSlide = index;

        slides[currentSlide].style.opacity = '1';
        dots[currentSlide].style.background = '#ef4444';
        dots[currentSlide].style.width = '24px';
        dots[currentSlide].style.borderRadius = '4px';
    }

    function nextSlide() {
        goToSlide((currentSlide + 1) % totalSlides);
    }

    setInterval(nextSlide, 4000);
</script>

<main class="container mx-auto px-4 py-12" style="display:flex; flex-direction:column; gap:80px; background:#0a0a0a;">

    <!-- Books Section -->
    <section id="books">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px; border-left:4px solid #eab308; padding-left:16px;">
            <div>
                <h2 class="text-3xl font-bold">Books</h2>
                <p class="text-gray-500">Mais lidos e novos lançamentos literários</p>
            </div>
            <a href="/Books" style="color:#2563eb; font-weight:600; font-size:14px;">Ver todos &rarr;</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
            @foreach (var book in Model.Books.Take(5))
            {
                <a href="/Books/Details/@book.Id" class="hover-card" style="display:block;">
                    <div style="aspect-ratio:2/3; border-radius:8px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                        <img src="@book.ImageUrl" alt="@book.Title" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/img/no-cover.jpg'" />
                    </div>
                    <div style="margin-top:10px;">
                        <h3 style="font-size:13px; font-weight:700; line-height:1.3; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">@book.Title</h3>
                        <p style="font-size:12px; color:#6b7280; margin-top:2px;">@book.Author</p>
                        @if (book.Rating > 0)
                        {
                            <span style="font-size:12px; color:#374151;">★ @book.Rating</span>
                        }
                    </div>
                </a>
            }
        </div>
    </section>

    <!-- Games Section -->
    <section id="games">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px; border-left:4px solid #a855f7; padding-left:16px;">
            <div>
                <h2 class="text-3xl font-bold">Games</h2>
                <p class="text-gray-500">Últimas notícias e reviews do mundo gamer</p>
            </div>
            <a href="/Games" style="color:#2563eb; font-weight:600; font-size:14px;">Ver todos &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Featured game -->
            @if (Model.Games.Any())
            {
                var featured = Model.Games.First();
                <div class="md:col-span-2">
                    <a href="/Games/Details/@featured.Id" class="hover-card" style="display:block; border-radius:12px; overflow:hidden; position:relative; aspect-ratio:16/9;">
                        <img src="@featured.ImageUrl" alt="@featured.Title" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/img/no-cover.jpg'" />
                        <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);"></div>
                        <div style="position:absolute; bottom:0; left:0; padding:24px;">
                            <h3 style="font-size:24px; font-weight:800; color:#fff; margin:0;">@featured.Title</h3>
                            <p style="font-size:13px; color:#ccc; margin-top:4px;">★ @featured.Rating</p>
                        </div>
                    </a>
                </div>

                <!-- Sidebar games -->
                <div style="display:flex; flex-direction:column; gap:16px;">
                    @foreach (var game in Model.Games.Skip(1).Take(4))
                    {
                        <a href="/Games/Details/@game.Id" class="hover-card" style="display:flex; gap:14px; align-items:center;">
                            <div style="width:80px; height:56px; border-radius:6px; overflow:hidden; flex-shrink:0;">
                                <img src="@game.ImageUrl" alt="@game.Title" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/img/no-cover.jpg'" />
                            </div>
                            <div>
                                <h3 style="font-size:14px; font-weight:700; line-height:1.3; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">@game.Title</h3>
                                @if (game.Rating > 0)
                                {
                                    <p style="font-size:12px; color:#6b7280; margin-top:2px;">★ @game.Rating</p>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>

    <!-- Movies & Animes Section -->
    <section id="movies" class="grid md:grid-cols-2 gap-12">

        <!-- Movies -->
        <div>
            <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px; border-left:4px solid #eab308; padding-left:16px;">
                <div>
                    <h2 class="text-2xl font-bold">Movies</h2>
                    <p style="font-size:13px; color:#6b7280;">Cinema e Streaming</p>
                </div>
                <a href="/Movies" style="color:#2563eb; font-weight:600; font-size:14px;">Ver todos &rarr;</a>
            </div>
            <div style="display:flex; flex-direction:column; gap:12px;">
                @if (Model.Movies.Any())
                {
                    var featuredMovie = Model.Movies.First();
                    <a href="/Movies/Details/@featuredMovie.Id" class="hover-card" style="display:block; border-radius:10px; overflow:hidden; aspect-ratio:16/9; position:relative;">
                        <img src="@featuredMovie.ImageUrl" alt="@featuredMovie.Title" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/img/no-cover.jpg'" />
                        <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);"></div>
                        <div style="position:absolute; bottom:0; left:0; padding:16px;">
                            <h3 style="font-size:18px; font-weight:800; color:#fff; margin:0;">@featuredMovie.Title</h3>
                        </div>
                    </a>
                    <div class="grid grid-cols-2 gap-3">
                        @foreach (var movie in Model.Movies.Skip(1).Take(2))
                        {
                            <a href="/Movies/Details/@movie.Id" class="hover-card" style="display:block; border-radius:8px; overflow:hidden; aspect-ratio:16/9; position:relative;">
                                <img src="@movie.ImageUrl" alt="@movie.Title" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/img/no-cover.jpg'" />
                                <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);"></div>
                                <div style="position:absolute; bottom:0; left:0; padding:10px;">
                                    <h3 style="font-size:12px; font-weight:700; color:#fff; margin:0; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">@movie.Title</h3>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Animes -->
        <div id="animes">
            <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px; border-left:4px solid #ec4899; padding-left:16px;">
                <div>
                    <h2 class="text-2xl font-bold">Animes</h2>
                    <p style="font-size:13px; color:#6b7280;">Os mais populares do momento</p>
                </div>
                <a href="/Animes" style="color:#2563eb; font-weight:600; font-size:14px;">Ver todos &rarr;</a>
            </div>
            <div class="grid grid-cols-3 gap-4">
                @foreach (var anime in Model.Animes.Take(6))
                {
                    <a href="/Animes/Details/@anime.Id" class="hover-card" style="display:block; text-align:center;">
                        <div style="aspect-ratio:2/3; border-radius:8px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                            <img src="@anime.ImageUrl" alt="@anime.Title" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/img/no-cover.jpg'" />
                        </div>
                        <p style="font-size:11px; font-weight:600; margin-top:6px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">@anime.Title</p>
                    </a>
                }
            </div>
        </div>

    </section>

    <!-- TV Shows Section -->
    <section id="tvshows">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px; border-left:4px solid #3b82f6; padding-left:16px;">
            <div>
                <h2 class="text-3xl font-bold">TV Shows</h2>
                <p class="text-gray-500">As séries mais vistas agora</p>
            </div>
            <a href="/TvShows" style="color:#2563eb; font-weight:600; font-size:14px;">Ver todos &rarr;</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
            @foreach (var show in Model.TvShows.Take(5))
            {
                <a href="/TvShows/Details/@show.Id" class="hover-card" style="display:block;">
                    <div style="aspect-ratio:2/3; border-radius:8px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                        <img src="@show.ImageUrl" alt="@show.Title" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/img/no-cover.jpg'" />
                    </div>
                    <div style="margin-top:10px;">
                        <h3 style="font-size:13px; font-weight:700; line-height:1.3; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">@show.Title</h3>
                        @if (show.Rating > 0)
                        {
                            <span style="font-size:12px; color:#374151;">★ @show.Rating</span>
                        }
                    </div>
                </a>
            }
        </div>
    </section>

</main>
