@model Universetechgeek.Models.RegisterViewModel

@{
    ViewData["Title"] = "Registar";
}

<main class="container mx-auto px-4 py-16 max-w-md">

    <div class="mb-8 border-l-4 border-blue-600 pl-4">
        <h2 class="text-3xl font-bold">Criar Conta</h2>
        <p class="text-gray-500">Junta-te à comunidade Universe TechGeek!</p>
    </div>

    <form asp-action="Register" method="post" class="space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

        <div>
            <label asp-for="DisplayName" class="block text-sm font-semibold mb-1">Nome</label>
            <input asp-for="DisplayName" type="text" placeholder="O teu nome"
                   class="w-full border border-gray-300 rounded-lg px-4 py-3 outline-none focus:border-blue-600 text-sm" />
            <span asp-validation-for="DisplayName" class="text-red-500 text-xs"></span>
        </div>

        <div>
            <label asp-for="Email" class="block text-sm font-semibold mb-1">Email</label>
            <input asp-for="Email" type="email" placeholder="email@exemplo.com"
                   class="w-full border border-gray-300 rounded-lg px-4 py-3 outline-none focus:border-blue-600 text-sm" />
            <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
        </div>

        <div>
            <label asp-for="Password" class="block text-sm font-semibold mb-1">Password</label>
            <input asp-for="Password" type="password" placeholder="••••••••"
                   class="w-full border border-gray-300 rounded-lg px-4 py-3 outline-none focus:border-blue-600 text-sm" />
            <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
        </div>

        <div>
            <label asp-for="ConfirmPassword" class="block text-sm font-semibold mb-1">Confirmar Password</label>
            <input asp-for="ConfirmPassword" type="password" placeholder="••••••••"
                   class="w-full border border-gray-300 rounded-lg px-4 py-3 outline-none focus:border-blue-600 text-sm" />
            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs"></span>
        </div>

        <button type="submit"
                class="w-full bg-black text-white py-3 rounded-lg font-semibold hover:bg-gray-800 transition">
            Criar Conta
        </button>
    </form>

    <div style="border-top:1px solid #e5e7eb; margin:24px 0;"></div>

    <form asp-action="ExternalLogin" asp-controller="Account" method="post">
        <input type="hidden" name="provider" value="Google" />
        <button type="submit"
                class="w-full border border-gray-300 py-3 rounded-lg font-semibold hover:bg-gray-50 transition flex items-center justify-center gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Registar com Google
        </button>
    </form>

    <p class="text-center text-sm mt-6 text-gray-500">
        Já tens conta?
        <a href="/Account/Login" class="text-blue-600 font-semibold hover:underline">Entrar</a>
    </p>

</main>
